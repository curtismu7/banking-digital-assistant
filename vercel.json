{
  "version": 2,

  "installCommand": "npm ci --prefix banking_api_server",
  "buildCommand": "npm ci --prefix banking_api_ui && npm run build --prefix banking_api_ui",
  "outputDirectory": "banking_api_ui/build",

  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/handler" }
  ],

  "headers": [
    {
      "source": "/api/:path*",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ]
}
